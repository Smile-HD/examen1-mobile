# ==========================================
# CONFIGURACIÓN DEL MOBILE (Flutter / flutter_dotenv)
# ==========================================

# Para Android Emulator, usa "http://10.0.2.2:8000" (se mapea a tu localhost).
# Para iOS Simulator / Web usa "http://localhost:8000".

# --- Local (Android)
#API_URL=http://192.168.0.147:8000/api/v1
#ENV=development

# --- Local (iOS / Web)
# API_URL=http://localhost:8000/api/v1
# ENV=development

# --- Producción (Tu servidor en la nube)
API_URL=https://emergencias1.onrender.com/api/v1
ENV=production

# Versión de la API u otras configuraciones variables
API_TIMEOUT_MS=20000
